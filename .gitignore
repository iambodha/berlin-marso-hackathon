# pixi environments
.pixi/*
!.pixi/config.toml

# run outputs / checkpoints
outputs/

# Windows CUDA shim (generated locally for SAPIEN GPU sim)
.cuda_shim/
cuda_dll/

# python
__pycache__/
*.pyc
*.egg-info/
.ipynb_checkpoints/
venv/

# editor / local settings
.vscode/
.claude/

# IL track generated artifacts
*.pt
il/videos/
*.h5
*.mp4
# Demo datasets (rgb) are large and exceed GitHub's file-size limit, so they are NOT in git —
# they're hosted as a Release asset and fetched with il/download_demos.py (see README). Only the
# small demo media (gif/mp4) ships in the repo.
!media/*_demo.mp4

# Diffusion policy local training runs (checkpoints/logs are large; keep config/results locally)
il/baselines/diffusion_policy/runs/**/checkpoints/
il/baselines/diffusion_policy/runs/**/events.out.tfevents.*
il/baselines/diffusion_policy/runs/**/videos/
events.out.tfevents.*

# run logs (training/eval/gen stdout captured to files)
*.log

# media / docs (local only)
*.gif
*.png
*.jpg
*.jpeg
*.pdf
*.docx
*.doc
*.xls
*.xlsx
